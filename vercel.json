{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/satpam",
      "destination": "http://103.93.129.57:9999/api/v1/client-order"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
